# ==============================================================================
# Environment Configuration Templates
# ==============================================================================
# - .env      : Local development environment settings (gitignored)
# - .env.dev  : Remote development environment settings (gitignored)
# - .env.prod : Production environment settings (gitignored)
# ==============================================================================

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_DOMAIN=stricktlycoffee.be

# Dokploy Configuration
DOKPLOY_API_KEY=your_dokploy_api_key
DOKPLOY_URL=https://dokploy.dyve.dev

# Compose IDs (configured in .env.dev and .env.prod)
DOKPLOY_COMPOSE_ID_SC=your_strictly_coffee_compose_id
DOKPLOY_COMPOSE_ID_PESADO=your_pesado_compose_id

# Domain parameters
DOMAIN=stricktlycoffee.be
PESADO_DOMAIN=pesado.stricktlycoffee.be
ADMIN_DOMAIN=admin.stricktlycoffee.be

# PostgreSQL Database Credentials
DB_HOST=postgres-db
DB_PORT=5432
DB_NAME=stricktlycoffee
DB_USER=sc_admin
DB_PASSWORD=your_secure_db_password_here

# Docker/Nginx Proxy Settings (for local/production container routing)
VIRTUAL_HOST=stricktlycoffee.be,www.stricktlycoffee.be,pesado.stricktlycoffee.be,admin.stricktlycoffee.be
LETSENCRYPT_HOST=stricktlycoffee.be,www.stricktlycoffee.be,pesado.stricktlycoffee.be,admin.stricktlycoffee.be
LETSENCRYPT_EMAIL=admin@stricktlycoffee.be
