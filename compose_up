#!/usr/bin/env bash
# compose_up
# Script to build and start the local environment with hot-reloading

set -euo pipefail

echo "☕ Strictly Coffee - Local Hot-Reload Boot"
echo "═════════════════════════════════════════════"
echo ""

# Check Docker status
if ! command -v docker >/dev/null 2>&1; then
  echo "❌ Error: Docker is not installed." >&2
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "❌ Error: Docker daemon is not running." >&2
  echo "Please start Docker Desktop and run this script again." >&2
  exit 1
fi

# Build and start services
echo "🚀 Building and starting containers in hot-reload mode..."
docker-compose -f docker-compose.local.yml down --remove-orphans 2>/dev/null || true
docker-compose -f docker-compose.local.yml up -d --build

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "✅ SUCCESS! Hot-reloading local environment is active!"
echo "═══════════════════════════════════════════════════════════"
echo ""
echo "🌐 Storefront (Strictly Coffee): http://localhost/"
echo "🛍️  Warehouse Shop (Pesado):       http://localhost:8081/"
echo "📦 Warehouse Simulator:           http://localhost:8081/warehouse.html"
echo "🔍 Order Tracker:                 http://localhost:8081/track.html"
echo ""
echo "💡 Hot-reloading is ACTIVE:"
echo "   - Web (Strictly Coffee): Edits in ./web reflect instantly."
echo "   - Warehouse (Pesado):     Edits in ./pesado reflect instantly."
echo "   - Backend:                Edits in ./server trigger auto-restart (node --watch)."
echo ""
echo "📋 Logs:       docker-compose -f docker-compose.local.yml logs -f"
echo "🛑 Stop:       docker-compose -f docker-compose.local.yml down"
echo "═══════════════════════════════════════════════════════════"
echo ""
